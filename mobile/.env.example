# Blur Mobile - Environment Configuration

# API URL (Backend server)
# For local development with simulator/emulator, use localhost
# For physical device testing, use your computer's IP address
EXPO_PUBLIC_API_URL=http://localhost:3000

# Socket.IO URL (Real-time server)
# Should match the API URL
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000

# Example for physical device testing:
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3000
# EXPO_PUBLIC_SOCKET_URL=http://192.168.1.100:3000

# To find your IP address:
# - Mac: System Preferences → Network
# - Windows: Run 'ipconfig' in Command Prompt
# - Linux: Run 'ifconfig' in Terminal
